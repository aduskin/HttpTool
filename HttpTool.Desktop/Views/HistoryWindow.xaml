<AduSkin:AduWindow
    x:Class="HttpTool.Desktop.Views.HistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Request History"
    Width="700"
    Height="500"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <AduSkin:AduDataGrid
            x:Name="HistoryGrid"
            Grid.Row="0"
            Margin="10"
            AutoGenerateColumns="False"
            HeadersVisibility="Column"
            IsReadOnly="True">
            <AduSkin:AduDataGrid.Columns>
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding ExecutedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                    Header="Time" />
                <DataGridTextColumn
                    Width="60"
                    Binding="{Binding Method}"
                    Header="Method" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Url}"
                    Header="URL" />
                <DataGridTextColumn
                    Width="60"
                    Binding="{Binding StatusCode}"
                    Header="Status" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding Elapsed.TotalMilliseconds, StringFormat='{}{0:F0} ms'}"
                    Header="Time" />
            </AduSkin:AduDataGrid.Columns>
        </AduSkin:AduDataGrid>

        <StackPanel
            Grid.Row="1"
            Margin="8"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <AduSkin:AduButton
                Margin="0,0,8,0"
                Click="ClearHistory_Click"
                Content="Clear History" />
            <AduSkin:AduButton Click="Close_Click" Content="Close" />
        </StackPanel>
    </Grid>
</AduSkin:AduWindow>
