<UserControl
    x:Class="HttpTool.Desktop.Views.RequestEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:HttpTool.Desktop.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:HttpTool.Desktop.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  API List Header  -->
        <Border
            Grid.Row="0"
            Padding="12,8"
            BorderBrush="{DynamicResource NormalBorderBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <AduSkin:AduFormBox Header="Project">
                    <AduSkin:AduEditableTextBlock
                        Width="Auto"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Text="{Binding Project.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </AduSkin:AduFormBox>

                <!--  Request Name  -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <AduSkin:AduFormBox Margin="10,0" Header="Name">
                        <AduSkin:AduTextBox
                            Grid.Row="1"
                            Width="200"
                            Text="{Binding SelectedApi.Name, UpdateSourceTrigger=PropertyChanged}" />
                    </AduSkin:AduFormBox>
                    <AduSkin:AduButton Command="{Binding NewApiCommand}" Content="New Request" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Content Area  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="200"
                    MinWidth="200"
                    MaxWidth="300" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  API List  -->
            <AduSkin:AduListBox
                Padding="0,4"
                BorderThickness="0"
                ItemsSource="{Binding Apis}"
                SelectedItem="{Binding SelectedApi}">
                <AduSkin:AduListBox.ItemContainerStyle>
                    <Style BasedOn="{StaticResource AduListBoxItem}" TargetType="AduSkin:AduListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="2,1" />
                    </Style>
                </AduSkin:AduListBox.ItemContainerStyle>
                <AduSkin:AduListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="30" Margin="0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Margin="6,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{Binding Method, Converter={StaticResource HttpMethodToColorConverter}}"
                                CornerRadius="3">
                                <TextBlock
                                    Margin="4,2"
                                    FontSize="10"
                                    Foreground="White"
                                    Text="{Binding Method}"
                                    TextAlignment="Center" />
                            </Border>
                            <TextBlock
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis" />
                            <AduSkin:AduPathIconButton
                                x:Name="btnClose"
                                Grid.Column="2"
                                Padding="4,0"
                                VerticalAlignment="Center"
                                AduAttach:PathDataAttach.PathData="{DynamicResource Icon_SystemClose}"
                                AduAttach:PathDataAttach.Width="8"
                                Command="{Binding DataContext.DeleteApiCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Visibility="Collapsed" />
                        </Grid>
                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnClose" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </AduSkin:AduListBox.ItemTemplate>
            </AduSkin:AduListBox>

            <AduSkin:AduGridSplitter
                Grid.Column="1"
                Width="Auto"
                ResizeDirection="Columns" />

            <!--  Request Editor  -->
            <Grid Grid.Column="2" Visibility="{Binding SelectedApi, Converter={StaticResource NullToCollapsedConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition
                        Height="Auto"
                        MinHeight="250"
                        MaxHeight="400" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  URL Bar  -->
                <Border
                    Grid.Row="0"
                    Padding="6"
                    BorderBrush="{DynamicResource NormalBorderBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Method Selector  -->
                        <AduSkin:AduComboBox
                            Grid.Column="0"
                            Width="86"
                            Margin="0,0,8,0"
                            ItemsSource="{Binding Source={x:Static local:HttpMethods.Values}}"
                            SelectedItem="{Binding SelectedApi.Method}" />

                        <!--  URL Input  -->
                        <AduSkin:AduTextBox
                            Grid.Column="1"
                            FontSize="14"
                            Text="{Binding SelectedApi.Url, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  Timeout  -->
                        <AduSkin:AduFormBox
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            Header="Timeout:"
                            Prompt="s"
                            PromptVisibility="Visible">
                            <AduSkin:AduIntegerUpDown Width="60" Value="{Binding SelectedApi.TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                        </AduSkin:AduFormBox>

                        <!--  Send Button  -->
                        <AduSkin:AduButton
                            Grid.Column="3"
                            Width="60"
                            Margin="8,0,0,0"
                            Background="{DynamicResource PrimaryBrush}"
                            BorderThickness="1"
                            Command="{Binding SendRequestCommand}"
                            CommandParameter="{Binding SelectedApi}">
                            <Path
                                Width="16"
                                Data="{DynamicResource Icon_Send}"
                                Fill="White" />
                        </AduSkin:AduButton>
                    </Grid>
                </Border>

                <!--  Tabs for Headers, Body, etc.  -->
                <AduSkin:AduTabControl
                    Grid.Row="1"
                    AduAttach:BorderAttach.CornerRadius="0"
                    BorderThickness="0">
                    <!--  Params Tab  -->
                    <AduSkin:AduTabItem Header="Params">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel
                                Grid.Row="0"
                                Margin="8"
                                Orientation="Horizontal">
                                <AduSkin:AduButton Click="AddParam_Click" Content="Add" />
                                <AduSkin:AduButton
                                    Margin="8,0,0,0"
                                    Click="DeleteParam_Click"
                                    Content="Delete" />
                            </StackPanel>
                            <AduSkin:AduDataGrid
                                Grid.Row="1"
                                AduAttach:BorderAttach.CornerRadius="0"
                                AutoGenerateColumns="False"
                                BorderThickness="0,1,0,0"
                                CanUserAddRows="False"
                                HeadersVisibility="Column"
                                ItemsSource="{Binding SelectedApi.QueryParams}"
                                SelectedItem="{Binding SelectedParam, Mode=TwoWay}"
                                SelectionMode="Single">
                                <AduSkin:AduDataGrid.Columns>
                                    <AduSkin:AduDataGridCheckBoxColumn
                                        Width="30"
                                        Binding="{Binding IsEnabled}"
                                        Header="" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                        EditingElementStyle="{DynamicResource EditTextColumnHorizontalLeft}"
                                        ElementStyle="{DynamicResource ReadOnlyTextColumnHorizontalLeft}"
                                        Header="Key" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                        EditingElementStyle="{DynamicResource EditTextColumnHorizontalLeft}"
                                        ElementStyle="{DynamicResource ReadOnlyTextColumnHorizontalLeft}"
                                        Header="Value" />
                                </AduSkin:AduDataGrid.Columns>
                            </AduSkin:AduDataGrid>
                        </Grid>
                    </AduSkin:AduTabItem>

                    <!--  Headers Tab  -->
                    <AduSkin:AduTabItem Header="Headers">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel
                                Grid.Row="0"
                                Margin="8"
                                Orientation="Horizontal">
                                <AduSkin:AduButton Click="AddHeader_Click" Content="Add" />
                                <AduSkin:AduButton
                                    Margin="8,0,0,0"
                                    Click="DeleteHeader_Click"
                                    Content="Delete" />
                            </StackPanel>
                            <AduSkin:AduDataGrid
                                Grid.Row="1"
                                AduAttach:BorderAttach.CornerRadius="0"
                                AutoGenerateColumns="False"
                                BorderThickness="0,1,0,0"
                                CanUserAddRows="False"
                                HeadersVisibility="Column"
                                ItemsSource="{Binding SelectedApi.Headers}"
                                SelectedItem="{Binding SelectedHeader, Mode=TwoWay}"
                                SelectionMode="Single">
                                <AduSkin:AduDataGrid.Columns>
                                    <AduSkin:AduDataGridCheckBoxColumn
                                        Width="30"
                                        Binding="{Binding IsEnabled}"
                                        Header="" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                        EditingElementStyle="{DynamicResource EditTextColumnHorizontalLeft}"
                                        ElementStyle="{DynamicResource ReadOnlyTextColumnHorizontalLeft}"
                                        Header="Key" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                        EditingElementStyle="{DynamicResource EditTextColumnHorizontalLeft}"
                                        ElementStyle="{DynamicResource ReadOnlyTextColumnHorizontalLeft}"
                                        Header="Value" />
                                </AduSkin:AduDataGrid.Columns>
                            </AduSkin:AduDataGrid>
                        </Grid>
                    </AduSkin:AduTabItem>

                    <!--  Body Tab  -->
                    <AduSkin:AduTabItem Header="Body">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Margin="8"
                                Orientation="Horizontal">
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="none"
                                    IsChecked="{Binding SelectedApi.BodyType, Converter={StaticResource EnumConverter}, ConverterParameter=None}" />
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="JSON"
                                    IsChecked="{Binding SelectedApi.BodyType, Converter={StaticResource EnumConverter}, ConverterParameter=Json}" />
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="XML"
                                    IsChecked="{Binding SelectedApi.BodyType, Converter={StaticResource EnumConverter}, ConverterParameter=Xml}" />
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="Form"
                                    IsChecked="{Binding SelectedApi.BodyType, Converter={StaticResource EnumConverter}, ConverterParameter=FormUrlEncoded}" />
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="Raw"
                                    IsChecked="{Binding SelectedApi.BodyType, Converter={StaticResource EnumConverter}, ConverterParameter=Raw}" />
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="Binary"
                                    IsChecked="{Binding SelectedApi.BodyType, Converter={StaticResource EnumConverter}, ConverterParameter=Binary}" />
                            </StackPanel>

                            <!--  Text Body  -->
                            <AduSkin:AduTextBox
                                Grid.Row="1"
                                Height="Auto"
                                Margin="8,0,8,8"
                                Padding="4"
                                VerticalAlignment="Stretch"
                                VerticalContentAlignment="Top"
                                AcceptsReturn="True"
                                AcceptsTab="True"
                                HorizontalScrollBarVisibility="Auto"
                                Text="{Binding SelectedApi.Body, UpdateSourceTrigger=PropertyChanged}"
                                VerticalScrollBarVisibility="Auto"
                                Visibility="{Binding SelectedApi.BodyType, Converter={StaticResource BinaryToCollapsedConverter}}" />

                            <!--  Binary File Upload  -->
                            <StackPanel
                                Grid.Row="1"
                                Margin="8"
                                Visibility="{Binding SelectedApi.BodyType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Binary}">
                                <TextBlock Text="Select file to upload:" />
                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                    <AduSkin:AduTextBox
                                        Width="300"
                                        IsReadOnly="True"
                                        Text="{Binding SelectedApi.BinaryFilePath}" />
                                    <AduSkin:AduButton
                                        Margin="8,0,0,0"
                                        Click="BrowseBinaryFile_Click"
                                        Content="Browse..." />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </AduSkin:AduTabItem>

                    <!--  Auth Tab  -->
                    <AduSkin:AduTabItem Header="Auth">
                        <StackPanel Margin="8">
                            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="None"
                                    IsChecked="{Binding SelectedApi.AuthType, Converter={StaticResource EnumConverter}, ConverterParameter=None}" />
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="Basic"
                                    IsChecked="{Binding SelectedApi.AuthType, Converter={StaticResource EnumConverter}, ConverterParameter=Basic}" />
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="Bearer"
                                    IsChecked="{Binding SelectedApi.AuthType, Converter={StaticResource EnumConverter}, ConverterParameter=Bearer}" />
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="API Key"
                                    IsChecked="{Binding SelectedApi.AuthType, Converter={StaticResource EnumConverter}, ConverterParameter=ApiKey}" />
                                <AduSkin:AduRadioButton
                                    Margin="0,0,16,0"
                                    Content="OAuth 2.0"
                                    IsChecked="{Binding SelectedApi.AuthType, Converter={StaticResource EnumConverter}, ConverterParameter=OAuth2}" />
                            </StackPanel>

                            <!--  Basic/Bearer/API Key Auth Value  -->
                            <AduSkin:AduTextBox
                                Margin="0,0,0,12"
                                Text="{Binding SelectedApi.AuthValue, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding SelectedApi.AuthType, Converter={StaticResource AuthValueVisibilityConverter}}" />

                            <!--  OAuth 2.0 Config  -->
                            <StackPanel Visibility="{Binding SelectedApi.AuthType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=OAuth2}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="Authorization URL:" />
                                    <AduSkin:AduTextBox
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="0,4"
                                        Text="{Binding SelectedApi.OAuthConfig.AuthorizationUrl, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="Token URL:" />
                                    <AduSkin:AduTextBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,4"
                                        Text="{Binding SelectedApi.OAuthConfig.TokenUrl, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="Client ID:" />
                                    <AduSkin:AduTextBox
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,4"
                                        Text="{Binding SelectedApi.OAuthConfig.ClientId, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="Client Secret:" />
                                    <AduSkin:AduTextBox
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Margin="0,4"
                                        Text="{Binding SelectedApi.OAuthConfig.ClientSecret, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock
                                        Grid.Row="4"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="Scope:" />
                                    <AduSkin:AduTextBox
                                        Grid.Row="4"
                                        Grid.Column="1"
                                        Margin="0,4"
                                        Text="{Binding SelectedApi.OAuthConfig.Scope, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock
                                        Grid.Row="5"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="Access Token:" />
                                    <AduSkin:AduTextBox
                                        Grid.Row="5"
                                        Grid.Column="1"
                                        Margin="0,4"
                                        Text="{Binding SelectedApi.OAuthConfig.AccessToken, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </AduSkin:AduTabItem>
                </AduSkin:AduTabControl>

                <AduSkin:AduGridSplitter Grid.Row="2" ResizeDirection="Rows" />
                <!--  Response Section  -->
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Response Header  -->
                    <Border
                        Grid.Row="0"
                        Padding="12,6,12,8"
                        BorderBrush="{DynamicResource NormalBorderBrush}"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="Response" />

                            <!--  Response Status  -->
                            <StackPanel
                                Grid.Column="1"
                                Margin="16,0"
                                Orientation="Horizontal"
                                Visibility="{Binding CurrentResponse, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="{Binding CurrentResponse.IsSuccess, Converter={StaticResource StatusColorConverter}}"
                                    Text="{Binding CurrentResponse.StatusCode}" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding CurrentResponse.StatusDescription}" />
                                <TextBlock Margin="16,0,0,0" Text="{Binding CurrentResponse.ElapsedMilliseconds, StringFormat='{}{0:F0} ms'}" />
                                <TextBlock Margin="16,0,0,0" Text="{Binding CurrentResponse.ContentLengthFormatted}" />
                            </StackPanel>

                            <!--  Loading Indicator  -->
                            <TextBlock
                                Grid.Column="2"
                                Margin="16,0"
                                Text="Sending request..."
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <!--  Error Message  -->
                            <TextBlock
                                Grid.Column="3"
                                Margin="16,0"
                                VerticalAlignment="Center"
                                Foreground="Red"
                                Text="{Binding CurrentResponse.ErrorMessage}"
                                TextTrimming="CharacterEllipsis"
                                ToolTip="{Binding CurrentResponse.ErrorMessage}"
                                Visibility="{Binding CurrentResponse.ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

                            <AduSkin:AduProgressBar
                                Grid.Column="4"
                                VerticalAlignment="Center"
                                AduAttach:HeaderAttach.Visible="Collapsed"
                                Maximum="100"
                                Minimum="0"
                                State="{Binding ProgressState}"
                                Value="{Binding CurrentProgress}" />
                        </Grid>
                    </Border>

                    <!--  Response Body  -->
                    <AduSkin:AduTextBox
                        Grid.Row="1"
                        Height="Auto"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Top"
                        AduAttach:BorderAttach.CornerRadius="0,0,6,6"
                        BorderThickness="0"
                        FontSize="10"
                        IsAutoScrollToBottom="True"
                        IsReadOnly="True"
                        MultipleLine="True"
                        Text="{Binding CurrentResponse.Body, Mode=OneWay}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Grid>

            <!--  Empty State for API Selection  -->
            <StackPanel
                Grid.Column="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding SelectedApi, Converter={StaticResource NullToVisibleConverter}}">
                <TextBlock FontSize="14" Text="Select or create an API request" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
