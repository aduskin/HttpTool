<AduSkin:AduWindow
    x:Class="HttpTool.Desktop.Views.WebSocketWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    Title="WebSocket / SSE"
    Width="800"
    Height="600"
    MinWidth="600"
    MinHeight="400"
    AduAttach:HeaderAttach.Background="{DynamicResource NormalTransparentBrush}"
    AduAttach:HeaderAttach.FontSize="14"
    AduAttach:HeaderAttach.Foreground="{DynamicResource NormalForeground}"
    AduAttach:HeaderAttach.Height="40"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Connection URL  -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AduSkin:AduTextBox
                x:Name="UrlTextBox"
                Grid.Column="0"
                Margin="0,0,8,0"
                Text="ws://localhost:8080" />

            <AduSkin:AduButton
                x:Name="ConnectButton"
                Grid.Column="1"
                Margin="0,0,8,0"
                Click="Connect_Click"
                Content="Connect" />

            <AduSkin:AduButton
                x:Name="DisconnectButton"
                Grid.Column="2"
                Click="Disconnect_Click"
                Content="Disconnect"
                IsEnabled="False" />
        </Grid>

        <!--  Messages  -->
        <AduSkin:AduTextBox
            x:Name="MessagesTextBox"
            Grid.Row="1"
            Height="Auto"
            VerticalAlignment="Stretch"
            AcceptsReturn="True"
            FontFamily="Consolas"
            FontSize="12"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="True"
            VerticalScrollBarVisibility="Auto" />

        <!--  Send Message  -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AduSkin:AduTextBox
                x:Name="MessageTextBox"
                Grid.Column="0"
                Margin="0,0,8,0"
                KeyDown="MessageTextBox_KeyDown" />

            <AduSkin:AduButton
                Grid.Column="1"
                Click="Send_Click"
                Content="Send" />
        </Grid>
    </Grid>
</AduSkin:AduWindow>
