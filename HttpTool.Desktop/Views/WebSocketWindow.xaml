<AduSkin:AduWindow
    x:Class="HttpTool.Desktop.Views.WebSocketWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:HttpTool.Desktop.Views"
    xmlns:vm="clr-namespace:HttpTool.Desktop.ViewModels"
    Title="WebSocket / SSE"
    Width="800"
    Height="600"
    MinWidth="600"
    MinHeight="400"
    AduAttach:HeaderAttach.Background="{DynamicResource NormalTransparentBrush}"
    AduAttach:HeaderAttach.FontSize="14"
    AduAttach:HeaderAttach.Foreground="{DynamicResource NormalForeground}"
    AduAttach:HeaderAttach.Height="40"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d"
    Closed="Window_Closed">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Connection URL  -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AduSkin:AduTextBox
                Grid.Column="0"
                Margin="0,0,8,0"
                IsEnabled="{Binding IsUrlEnabled}"
                Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />

            <AduSkin:AduButton
                Grid.Column="1"
                Margin="0,0,8,0"
                Command="{Binding ConnectCommand}"
                Content="Connect"
                IsEnabled="{Binding IsConnectEnabled}" />

            <AduSkin:AduButton
                Grid.Column="2"
                Command="{Binding DisconnectCommand}"
                Content="Disconnect"
                IsEnabled="{Binding IsDisconnectEnabled}" />
        </Grid>

        <!--  Messages  -->
        <AduSkin:AduTextBox
            Grid.Row="1"
            Height="Auto"
            VerticalAlignment="Stretch"
            AcceptsReturn="True"
            FontFamily="Consolas"
            FontSize="12"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="True"
            VerticalScrollBarVisibility="Auto"
            Text="{Binding MessagesText, Mode=OneWay}" />

        <!--  Send Message  -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AduSkin:AduTextBox
                Grid.Column="0"
                Margin="0,0,8,0"
                Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}" />

            <AduSkin:AduButton
                Grid.Column="1"
                Command="{Binding SendCommand}"
                Content="Send" />
        </Grid>
    </Grid>
</AduSkin:AduWindow>
