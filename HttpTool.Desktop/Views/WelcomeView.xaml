<UserControl
    x:Class="HttpTool.Desktop.Views.WelcomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin">
    <Border Background="{DynamicResource NormalBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel
                Margin="0,120,0,30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <TextBlock
                    FontSize="30"
                    Text="HttpTool"
                    TextAlignment="Center" />
                <TextBlock
                    Margin="0,8,0,16"
                    Text="Create a new project or open an existing one."
                    TextAlignment="Center" />
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AduSkin:AduButton
                        Margin="0,0,8,0"
                        Background="{DynamicResource PrimaryBrush}"
                        BorderThickness="0"
                        Command="{Binding NewProjectCommand}"
                        Content="New Project"
                        Foreground="White" />
                    <AduSkin:AduButton Command="{Binding OpenProjectCommand}" Content="Open Project" />
                </StackPanel>
            </StackPanel>

            <AduSkin:AduListBox
                Grid.Row="1"
                MaxWidth="500"
                Margin="0,0,0,40"
                HorizontalContentAlignment="Stretch"
                ItemsSource="{Binding RecentProjects}"
                Visibility="{Binding RecentProjects.Count, Converter={StaticResource ZeroToCollapsedConverter}}">
                <AduSkin:AduListBox.ItemTemplate>
                    <DataTemplate>
                        <AduSkin:AduButton
                            Width="Auto"
                            Height="Auto"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="5">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="Medium"
                                        Text="{Binding FileName}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="#888"
                                        Text="{Binding FilePath}"
                                        TextTrimming="CharacterEllipsis"
                                        ToolTip="{Binding FilePath}" />
                                </StackPanel>
                                <AduSkin:AduPathIconButton
                                    x:Name="btnRemove"
                                    Grid.Column="1"
                                    AduAttach:PathDataAttach.PathData="{DynamicResource Icon_SystemClose}"
                                    Command="{Binding DataContext.RemoveProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="Collapsed" />
                            </Grid>
                        </AduSkin:AduButton>
                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnRemove" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </AduSkin:AduListBox.ItemTemplate>
                <AduSkin:AduListBox.ItemContainerStyle>
                    <Style BasedOn="{StaticResource AduListBoxItem}" TargetType="AduSkin:AduListBoxItem">
                        <Setter Property="Padding" Value="6" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Cursor" Value="Hand" />
                    </Style>
                </AduSkin:AduListBox.ItemContainerStyle>
            </AduSkin:AduListBox>
        </Grid>
    </Border>
</UserControl>