<AduSkin:AduWindow
    x:Class="HttpTool.Desktop.Views.ProxySettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:HttpTool.Desktop.ViewModels"
    Title="Proxy Settings"
    Width="500"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <AduSkin:AduWindow.DataContext>
        <vm:ProxySettingsWindowViewModel />
    </AduSkin:AduWindow.DataContext>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <TextBlock
            Grid.Row="0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="Proxy Settings" />

        <!--  Settings  -->
        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <!--  Enable Proxy  -->
            <AduSkin:AduCheckBox
                Margin="0,0,0,16"
                Content="Enable Proxy"
                IsChecked="{Binding ProxyEnabled}" />

            <!--  Proxy Type  -->
            <TextBlock Margin="0,0,0,4" Text="Proxy Type" />
            <AduSkin:AduComboBox
                Width="200"
                Margin="0,0,0,16"
                HorizontalAlignment="Left"
                ItemsSource="{Binding ProxyTypes}"
                SelectedItem="{Binding ProxyType}" />

            <!--  Proxy Host  -->
            <TextBlock Margin="0,0,0,4" Text="Proxy Host" />
            <AduSkin:AduTextBox
                Width="300"
                Margin="0,0,0,8"
                HorizontalAlignment="Left"
                Text="{Binding ProxyHost, UpdateSourceTrigger=PropertyChanged}" />

            <!--  Proxy Port  -->
            <TextBlock Margin="0,0,0,4" Text="Proxy Port" />
            <AduSkin:AduTextBox
                Width="100"
                Margin="0,0,0,8"
                HorizontalAlignment="Left"
                Text="{Binding ProxyPort, UpdateSourceTrigger=PropertyChanged}" />

            <!--  Username  -->
            <TextBlock Margin="0,0,0,4" Text="Username (Optional)" />
            <AduSkin:AduTextBox
                Width="200"
                Margin="0,0,0,8"
                HorizontalAlignment="Left"
                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

            <!--  Password  -->
            <TextBlock Margin="0,0,0,4" Text="Password (Optional)" />
            <AduSkin:AduTextBox
                Width="200"
                Margin="0,0,0,8"
                HorizontalAlignment="Left"
                Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <!--  Buttons  -->
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <AduSkin:AduButton
                Margin="0,0,8,0"
                Click="Save_Click"
                Content="Save" />
            <AduSkin:AduButton
                Click="Close_Click"
                Content="Cancel" />
        </StackPanel>
    </Grid>
</AduSkin:AduWindow>
