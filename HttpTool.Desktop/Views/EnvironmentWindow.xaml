<AduSkin:AduWindow
    x:Class="HttpTool.Desktop.Views.EnvironmentWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:HttpTool.Desktop.ViewModels"
    Title="Environment Variables"
    Width="600"
    Height="450"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <AduSkin:AduWindow.DataContext>
        <vm:EnvironmentWindowViewModel />
    </AduSkin:AduWindow.DataContext>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            FontSize="14"
            FontWeight="SemiBold"
            Text="Environment Variables" />

        <!-- Variables List -->
        <AduSkin:AduDataGrid
            Grid.Row="1"
            Margin="0,12,0,0"
            AutoGenerateColumns="False"
            BorderThickness="1"
            CanUserAddRows="False"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            ItemsSource="{Binding Variables}">
            <AduSkin:AduDataGrid.Columns>
                <AduSkin:AduDataGridCheckBoxColumn
                    Width="40"
                    Binding="{Binding IsEnabled}"
                    Header="" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                    Header="Variable" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                    Header="Value" />
            </AduSkin:AduDataGrid.Columns>
        </AduSkin:AduDataGrid>

        <!-- Buttons -->
        <StackPanel
            Grid.Row="2"
            Margin="0,12,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <AduSkin:AduButton
                Margin="0,0,8,0"
                Command="{Binding AddCommand}"
                Content="Add Variable" />
            <AduSkin:AduButton
                Margin="0,0,8,0"
                Command="{Binding SaveCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=AduSkin:AduWindow}}"
                Content="Save" />
            <AduSkin:AduButton
                Command="{Binding CloseCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=AduSkin:AduWindow}}"
                Content="Close" />
        </StackPanel>
    </Grid>
</AduSkin:AduWindow>
