<AduSkin:AduWindow
    x:Class="HttpTool.Desktop.Views.CodeGeneratorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    Title="Generate Code"
    Width="700"
    Height="500"
    MinWidth="500"
    MinHeight="400"
    AduAttach:HeaderAttach.Background="{DynamicResource NormalTransparentBrush}"
    AduAttach:HeaderAttach.FontSize="14"
    AduAttach:HeaderAttach.Foreground="{DynamicResource NormalForeground}"
    AduAttach:HeaderAttach.Height="40"
    AduAttach:HeaderAttach.IconWidth="20"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Language Selection  -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Margin="0,0,0,8" Text="Select Language:" />
            <AduSkin:AduComboBox
                x:Name="LanguageComboBox"
                DisplayMemberPath="DisplayName"
                SelectionChanged="LanguageComboBox_SelectionChanged" />
        </StackPanel>

        <!--  Code Display  -->
        <AduSkin:AduTextBox
            x:Name="CodeTextBox"
            Grid.Row="1"
            Height="Auto"
            Padding="4"
            VerticalAlignment="Stretch"
            VerticalContentAlignment="Top"
            AcceptsReturn="True"
            FontFamily="Consolas"
            FontSize="12"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="True"
            VerticalScrollBarVisibility="Auto" />

        <!--  Buttons  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,12,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <AduSkin:AduButton
                x:Name="CopyButton"
                Width="80"
                Margin="0,0,8,0"
                Click="Copy_Click"
                Content="Copy" />
            <AduSkin:AduButton
                Width="80"
                Click="Close_Click"
                Content="Close" />
        </StackPanel>
    </Grid>
</AduSkin:AduWindow>
